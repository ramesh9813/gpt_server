    {
      "name": "Folders",
      "item": [
        {
          "name": "POST Create Folder",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const id = json?.data?.folder?.id;",
                  "  if (id) pm.collectionVariables.set('folderId', id);",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
